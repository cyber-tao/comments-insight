{
  "name": "comments-insight",
  "version": "0.5.9",
  "description": "AI-powered comment extraction and analysis Chrome extension",
  "type": "module",
  "packageManager": "bun@1.3.11",
  "engines": {
    "node": ">=20.19.0 || >=22.12.0",
    "bun": ">=1.3.11"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "package": "bun run build && bun scripts/package.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,css,html}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md,css,html}\"",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "audit": "bun audit --prod --audit-level=high"
  },
  "dependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "dexie": "^4.4.1",
    "i18next": "^25.6.3",
    "lz-string": "^1.5.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^16.5.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.4.0",
    "@eslint/js": "^9.39.4",
    "@testing-library/react": "^16.3.2",
    "@types/chrome": "^0.1.31",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/react-i18next": "^7.8.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.4.22",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "fake-indexeddb": "^6.2.5",
    "fflate": "^0.8.2",
    "globals": "^16.2.0",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "puppeteer": "^24.42.0",
    "tailwindcss": "^3.4.18",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^6.4.2",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "undici": "^7.24.4",
    "rollup": "^4.60.0",
    "basic-ftp": "^5.3.0",
    "lodash": "^4.17.23",
    "flatted": "^3.4.2"
  }
}
